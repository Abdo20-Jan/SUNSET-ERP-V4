{
  "name": "sunset-erp-v4",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "biome:check": "biome check src/",
    "biome:format": "biome check --write src/",
    "biome:ci": "biome ci src/",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:push:force": "prisma db push --force-reset",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma db push && tsx prisma/seed.ts",
    "db:backfill-stock": "tsx prisma/backfill-stock-por-deposito.ts",
    "db:validar-stock": "tsx prisma/validar-invariantes-stock.ts",
    "db:partial-indexes-contenedor": "tsx prisma/add-partial-indexes-contenedor.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.1",
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.2.2",
    "@hugeicons/core-free-icons": "^4.1.4",
    "@hugeicons/react": "^1.1.6",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.25",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.2.1",
    "decimal.js": "^10.6.0",
    "next": "^16",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "react": "19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.76.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "prisma": "^7.8.0",
    "shadcn": "^4.7.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": "^8.5.10",
      "@hono/node-server@<1.19.13": "^1.19.13",
      "qs@<6.15.2": "^6.15.2"
    },
    "onlyBuiltDependencies": ["esbuild"]
  }
}
