{
  "name": "sunset-erp-v4",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "biome:check": "biome check src/",
    "biome:format": "biome check --write src/",
    "biome:ci": "biome ci src/",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:push:force": "echo 'PELIGRO: --force-reset BORRA TODA la base y DATABASE_URL apunta a PROD por defecto. Para resetear una base LOCAL corré explícito: DATABASE_URL=postgresql://localhost/tu_db_local pnpm exec prisma db push --force-reset' && exit 1",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-retenciones": "tsx prisma/seed-parametros-retencion.ts",
    "db:seed-ipc": "tsx prisma/seed-ipc-indec.ts",
    "db:setup": "prisma db push && tsx prisma/seed.ts",
    "db:backfill-stock": "tsx prisma/backfill-stock-por-deposito.ts",
    "db:validar-stock": "tsx prisma/validar-invariantes-stock.ts",
    "db:validar-asientos": "tsx prisma/validar-invariantes-asiento.ts",
    "db:partial-indexes-contenedor": "tsx prisma/add-partial-indexes-contenedor.ts",
    "db:partial-indexes-despacho": "tsx prisma/add-partial-indexes-despacho.ts",
    "db:sync": "prisma db push && tsx prisma/add-partial-indexes-contenedor.ts --apply && tsx prisma/add-partial-indexes-despacho.ts --apply",
    "db:backup:prod": "bash scripts/backup-prod.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "NODE_OPTIONS=\"--import tsx\" playwright test"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@hugeicons/core-free-icons": "^4.2.0",
    "@hugeicons/react": "^1.1.7",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.0",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "decimal.js": "^10.6.0",
    "exceljs": "^4.4.0",
    "next": "^16",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "pg": "^8.21.0",
    "react": "19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.78.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@testcontainers/postgresql": "^12.0.1",
    "@types/node": "^25",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "prisma": "^7.8.0",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": "^8.5.10",
      "@hono/node-server@<1.19.13": "^1.19.13",
      "qs@<6.15.2": "^6.15.2"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
