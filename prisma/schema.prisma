  usuario User @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@index([tabla, registroId])
}

// ============================================================
// GASTOS FIJOS (alquiler, contador, internet, etc — recurrentes)
// ============================================================

// Template de gasto recurrente. El usuario lo crea una vez con monto
// base y luego "registra" cada mes — eso genera un Asiento contable
// (DEBE gasto / HABER proveedor) y queda como cuenta a pagar hasta
// que se pague vía Tesorería.
model GastoFijo {
  id                    Int      @id @default(autoincrement())
  descripcion           String
  proveedorId           String
  // Override del default del proveedor (si vacío, usa proveedor.cuentaGastoContableId
  // o el fallback por tipoProveedor).
  cuentaGastoContableId Int?
  moneda                Moneda   @default(ARS)
  montoNeto             Decimal  @db.Decimal(18, 2)
  ivaPorcentaje         Decimal  @default(21) @db.Decimal(5, 2)
  iibbPorcentaje        Decimal  @default(0) @db.Decimal(5, 2)
  // Día del mes en que vence (1-28 para evitar feb). Opcional.
  diaVencimiento        Int?
  activo                Boolean  @default(true)
  notas                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  proveedor           Proveedor           @relation(fields: [proveedorId], references: [id])
  cuentaGastoContable CuentaContable?     @relation(fields: [cuentaGastoContableId], references: [id])
  registros           GastoFijoRegistro[]

  @@index([proveedorId])
  @@index([activo])
}

// Registro mensual de un GastoFijo — apunta al asiento generado.
// Único por (gastoFijoId, año, mes) para prevenir doble registro.
model GastoFijoRegistro {
  id           Int      @id @default(autoincrement())
  gastoFijoId  Int
  periodoYear  Int
  periodoMonth Int
  fecha        DateTime
  tipoCambio   Decimal  @default(1) @db.Decimal(18, 6)
  montoNeto    Decimal  @db.Decimal(18, 2)
  iva          Decimal  @db.Decimal(18, 2)
  iibb         Decimal  @db.Decimal(18, 2)
  total        Decimal  @db.Decimal(18, 2)
  asientoId    String?  @unique
  createdAt    DateTime @default(now())

  gastoFijo GastoFijo @relation(fields: [gastoFijoId], references: [id], onDelete: Cascade)
  asiento   Asiento?  @relation(fields: [asientoId], references: [id])

  @@unique([gastoFijoId, periodoYear, periodoMonth])
  @@index([periodoYear, periodoMonth])
}

// ============================================================
// IMPORTACIÓN DE EXTRACTOS BANCARIOS (con sugerencias IA)
// ============================================================

enum ImportacionExtractoStatus {
  PENDIENTE
  PARCIAL
  COMPLETADO
  CANCELADO
}

enum LineaExtractoStatus {
  PENDIENTE
  APROBADA
  RECHAZADA
  IGNORADA
}

model ImportacionExtracto {
  id               String                    @id @default(uuid())
  cuentaBancariaId String
  periodoYear      Int
  periodoMonth     Int
  saldoInicial     Decimal                   @db.Decimal(18, 2)
  saldoFinal       Decimal                   @db.Decimal(18, 2)
  archivoNombre    String?
  status           ImportacionExtractoStatus @default(PENDIENTE)
  totalLineas      Int                       @default(0)
  lineasAprobadas  Int                       @default(0)
  modeloIA         String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  cuentaBancaria CuentaBancaria            @relation(fields: [cuentaBancariaId], references: [id])
  lineas         LineaExtractoSugerencia[]

  @@unique([cuentaBancariaId, periodoYear, periodoMonth])
  @@index([status])
}

model LineaExtractoSugerencia {
  id            String   @id @default(uuid())
  importacionId String
  ordenLinea    Int
  fecha         DateTime
  descripcion   String
  comprobante   String?
  monto         Decimal  @db.Decimal(18, 2)
  saldoExtracto Decimal? @db.Decimal(18, 2)

  cuentaSugeridaId    Int?
  proveedorSugeridoId String?
  clienteSugeridoId   String?
  descripcionAsiento  String?
  confianza           String?
  razonSugerencia     String?

  status       LineaExtractoStatus @default(PENDIENTE)
  movimientoId String?             @unique
  notas        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  importacion    ImportacionExtracto  @relation(fields: [importacionId], references: [id], onDelete: Cascade)
  cuentaSugerida CuentaContable?      @relation(fields: [cuentaSugeridaId], references: [id])
  proveedor      Proveedor?           @relation(fields: [proveedorSugeridoId], references: [id])
  cliente        Cliente?             @relation(fields: [clienteSugeridoId], references: [id])
  movimiento     MovimientoTesoreria? @relation(fields: [movimientoId], references: [id])

  @@index([importacionId, ordenLinea])
  @@index([status])
}

// Cotización USD (1 USD = `valor` ARS). Usada para mostrar reportes en USD.
// Se elige el TC vigente más reciente cuya `fecha` sea <= la fecha de corte del reporte.
model Cotizacion {
  id        Int      @id @default(autoincrement())
  fecha     DateTime @unique @db.Date
  valor     Decimal  @db.Decimal(18, 6)
  fuente    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fecha])
}
