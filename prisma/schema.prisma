// Sunset Tires ERP v4 — Prisma schema
// Fonte da verdade: vault Obsidian `sunset-tires-brain` (acessado exclusivamente via MCP).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  ADMIN
  USER
}

enum CuentaTipo {
  SINTETICA
  ANALITICA
}

enum CuentaCategoria {
  ACTIVO
  PASIVO
  PATRIMONIO
  INGRESO
  EGRESO
}

enum PeriodoEstado {
  ABIERTO
  CERRADO
}

enum AsientoEstado {
  BORRADOR
  CONTABILIZADO
  ANULADO
}

enum AsientoOrigen {
  MANUAL
  TESORERIA
  COMEX
  AJUSTE
  GASTO
}

enum TipoCuentaBancaria {
  CUENTA_CORRIENTE
  CAJA_AHORRO
  CAJA_CHICA
}

enum Moneda {
  ARS
  USD
}

enum MovimientoTesoreriaTipo {
  PAGO
  COBRO
  TRANSFERENCIA
}

enum PrestamoClasificacion {
  CORTO_PLAZO
  LARGO_PLAZO
}

enum EmbarqueEstado {
  BORRADOR
  EN_TRANSITO
  EN_PUERTO
  EN_ZONA_PRIMARIA // mercadería llegó al puerto / zona primaria aduanera; costos ZP cerrados; aún NO disponible para venta
  EN_ADUANA
  DESPACHADO
  EN_DEPOSITO
  CERRADO
}

// Momento del costo dentro del flujo de importación.
// - ZONA_PRIMARIA: costos previos al despacho (puerto, flete terrestre,
//   operador logístico, gastos locales línea marítima).
// - DESPACHO: costos del despacho aduanero (despachante, DIA, operador
//   logístico) — cuando la mercadería se nacionaliza.
enum MomentoCosto {
  ZONA_PRIMARIA
  DESPACHO
}

// Estado de un despacho aduanero (oficialización parcial o total de un
// embarque). Un embarque puede tener 1..N despachos cuando la
// nacionalización ocurre en tandas.
enum DespachoEstado {
  BORRADOR
  CONTABILIZADO
  ANULADO
}

enum TipoCostoEmbarque {
  FLETE_INTERNACIONAL
  FLETE_NACIONAL
  SEGURO_MARITIMO
  GASTOS_PORTUARIOS
  HONORARIOS_DESPACHANTE
  OPERADOR_LOGISTICO
  ALMACENAJE
  DEVOLUCION_CONTENEDOR
  AGENTE_DE_CARGAS
  GASTOS_LOCALES
  GASTOS_EXTRAS
}

// Incoterms 2020 (cláusulas de comercio internacional).
// Determinan quién paga qué y cuándo se transfiere el riesgo.
enum Incoterm {
  EXW // Ex Works — comprador asume todo desde la fábrica
  FCA // Free Carrier — vendedor entrega al transportista designado
  FAS // Free Alongside Ship — costado del buque, puerto origen
  FOB // Free on Board — a bordo del buque, puerto origen
  CFR // Cost and Freight — incluye flete, no seguro
  CIF // Cost, Insurance and Freight — incluye flete + seguro
  CPT // Carriage Paid To
  CIP // Carriage and Insurance Paid To
  DAP // Delivered at Place
  DPU // Delivered at Place Unloaded
  DDP // Delivered Duty Paid — vendedor asume todo
}

// Estado de pedidos de compra/venta — flujo borrador hasta cierre.
enum PedidoEstado {
  BORRADOR
  ENVIADO // Pedido emitido al proveedor / enviado al cliente
  CONFIRMADO // Confirmado por la contraparte
  PARCIAL // Facturado/recibido parcialmente
  COMPLETADO // Totalmente facturado/recibido
  CANCELADO
}

// Condición de pago estándar — cómo se paga la factura.
enum CondicionPago {
  CONTADO
  TRANSFERENCIA
  CHEQUE
  TARJETA
  CUENTA_CORRIENTE
  OTRO
}

enum CompraEstado {
  BORRADOR
  EMITIDA
  RECIBIDA
  CANCELADA
}

// Estado de un gasto local (factura ad-hoc de proveedor con N líneas
// + IVA/IIBB header — ver model Gasto). Sigue la lógica de embarque
// cost: BORRADOR es editable, CONTABILIZADO genera asiento, ANULADO
// reverte el asiento.
enum GastoEstado {
  BORRADOR
  CONTABILIZADO
  ANULADO
}

enum VentaEstado {
  BORRADOR
  EMITIDA
  CANCELADA
}

enum EntregaEstado {
  BORRADOR
  CONFIRMADA
  ANULADA
}

enum TransferenciaEstado {
  CONFIRMADA
  ANULADA
}

enum MovimientoStockTipo {
  INGRESO
  EGRESO
  AJUSTE
  TRANSFERENCIA
}

enum CondicionIva {
  RI
  MONOTRIBUTO
  EXENTO
  CONSUMIDOR_FINAL
  EXTERIOR
}

enum TipoCanal {
  MAYORISTA
  MINORISTA
  REVENDEDOR_GOMERIA
  TRANSPORTISTA
  GRANDE_CUENTA
  EXTERIOR
  CONSUMIDOR_FINAL
}

enum TipoProveedor {
  MERCADERIA_LOCAL
  DESPACHANTE
  LOGISTICA
  ALMACENAJE
  SERVICIOS_PROFESIONALES
  ALQUILERES
  IT_SOFTWARE
  GASTOS_PORTUARIOS
  MARKETING
  OTRO
  MERCADERIA_EXTERIOR
  SERVICIOS_EXTERIOR
}

enum ConceptoRG830 {
  BIENES_DE_CAMBIO
  HONORARIOS
  ALQUILERES
  SERVICIOS_GENERALES
  LOCACIONES_SERVICIOS
}

enum AuditAccion {
  CREATE
  UPDATE
  DELETE
}

// ============================================================
// AUTENTICACIÓN
// ============================================================

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  nombre       String
  role         Role     @default(USER)
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs     AuditLog[]
  leads         Lead[]
  oportunidades Oportunidad[]
  actividades   Actividad[]
}

// ============================================================
// CONTABILIDAD
// ============================================================

model CuentaContable {
  id          Int             @id @default(autoincrement())
  codigo      String          @unique
  nombre      String
  tipo        CuentaTipo
  categoria   CuentaCategoria
  nivel       Int
  padreCodigo String?
  activa      Boolean         @default(true)

  padre CuentaContable?  @relation("CuentaPadre", fields: [padreCodigo], references: [codigo])
  hijos CuentaContable[] @relation("CuentaPadre")

  lineas              LineaAsiento[]
  cuentasBancarias    CuentaBancaria[]
  clientes            Cliente[]
  proveedores         Proveedor[]               @relation("ProveedorPasivo")
  proveedoresGasto    Proveedor[]               @relation("ProveedorGasto")
  prestamos           PrestamoExterno[]
  movimientos         MovimientoTesoreria[]
  embarqueCostoLineas EmbarqueCostoLinea[]      @relation("EmbarqueCostoLineaCuentaGasto")
  extractoLineas      LineaExtractoSugerencia[]
  gastosFijos         GastoFijo[]
  lineasGasto         LineaGasto[]              @relation("LineaGastoCuentaGasto")
}

model PeriodoContable {
  id          Int           @id @default(autoincrement())
  codigo      String        @unique
  nombre      String
  fechaInicio DateTime
  fechaFin    DateTime
  estado      PeriodoEstado @default(ABIERTO)

  asientos Asiento[]
}

model Asiento {
  id          String        @id @default(uuid())
  numero      Int
  fecha       DateTime
  descripcion String
  estado      AsientoEstado @default(BORRADOR)
  totalDebe   Decimal       @db.Decimal(18, 2)
  totalHaber  Decimal       @db.Decimal(18, 2)
  origen      AsientoOrigen
  moneda      Moneda        @default(ARS)
  tipoCambio  Decimal       @default(1) @db.Decimal(18, 6)
  periodoId   Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  periodo              PeriodoContable      @relation(fields: [periodoId], references: [id])
  lineas               LineaAsiento[]
  movimiento           MovimientoTesoreria?
  prestamo             PrestamoExterno?
  venta                Venta?
  compra               Compra?
  embarqueCierre       Embarque?            @relation("EmbarqueAsientoCierre")
  embarqueZonaPrimaria Embarque?            @relation("EmbarqueAsientoZP")
  despacho             Despacho?
  gastoFijoRegistro    GastoFijoRegistro?
  gasto                Gasto?
  chequeRecibidoCobro  ChequeRecibido?
  entregaVenta         EntregaVenta?

  @@unique([periodoId, numero])
  @@index([fecha])
  @@index([estado])
}

model LineaAsiento {
  id          Int     @id @default(autoincrement())
  asientoId   String
  cuentaId    Int
  debe        Decimal @default(0) @db.Decimal(18, 2)
  haber       Decimal @default(0) @db.Decimal(18, 2)
  descripcion String?

  asiento Asiento        @relation(fields: [asientoId], references: [id], onDelete: Restrict)
  cuenta  CuentaContable @relation(fields: [cuentaId], references: [id])

  @@index([cuentaId])
}

// ============================================================
// TESORERÍA
// ============================================================

model CuentaBancaria {
  id               String             @id @default(uuid())
  banco            String
  tipo             TipoCuentaBancaria
  moneda           Moneda
  numero           String?
  cbu              String?
  alias            String?
  cuentaContableId Int
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  cuentaContable CuentaContable        @relation(fields: [cuentaContableId], references: [id])
  movimientos    MovimientoTesoreria[]
  prestamos      PrestamoExterno[]
  importaciones  ImportacionExtracto[]
}

model MovimientoTesoreria {
  id               String                  @id @default(uuid())
  tipo             MovimientoTesoreriaTipo
  cuentaBancariaId String
  monto            Decimal                 @db.Decimal(18, 2)
  moneda           Moneda
  tipoCambio       Decimal                 @db.Decimal(18, 6)
  fecha            DateTime
  cuentaContableId Int
  asientoId        String?                 @unique
  descripcion      String?
  comprobante      String?
  referenciaBanco  String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  cuentaBancaria CuentaBancaria           @relation(fields: [cuentaBancariaId], references: [id])
  cuentaContable CuentaContable           @relation(fields: [cuentaContableId], references: [id])
  asiento        Asiento?                 @relation(fields: [asientoId], references: [id])
  lineaExtracto  LineaExtractoSugerencia?

  @@index([fecha])
}

model PrestamoExterno {
  id               String                @id @default(uuid())
  prestamista      String
  cuentaBancariaId String
  moneda           Moneda
  principal        Decimal               @db.Decimal(18, 2)
  tipoCambio       Decimal               @db.Decimal(18, 6)
  clasificacion    PrestamoClasificacion
  cuentaContableId Int
  asientoId        String?               @unique
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  cuentaBancaria CuentaBancaria @relation(fields: [cuentaBancariaId], references: [id])
  cuentaContable CuentaContable @relation(fields: [cuentaContableId], references: [id])
  asiento        Asiento?       @relation(fields: [asientoId], references: [id])
}

// ============================================================
// COMEX
// ============================================================

model Embarque {
  id                     String         @id @default(uuid())
  codigo                 String         @unique
  proveedorId            String
  estado                 EmbarqueEstado @default(BORRADOR)
  moneda                 Moneda
  tipoCambio             Decimal        @db.Decimal(18, 6)
  incoterm               Incoterm?
  lugarIncoterm          String? // ej: "Shanghai", "Buenos Aires"
  // Valores que el proveedor del exterior incluyó en el precio de venta
  // según el incoterm (informativos; no generan asientos separados):
  // - CIF: el proveedor contrató flete + seguro hasta destino
  // - CFR: el proveedor contrató sólo flete (comprador asegura)
  valorFleteOrigen       Decimal?       @db.Decimal(18, 2)
  valorSeguroOrigen      Decimal?       @db.Decimal(18, 2)
  pedidoCompraId         Int? // link opcional a OC que originó el embarque
  // Datos de transporte
  nombreBuque            String? // nombre del navío (ej: MSC GAYANE)
  lineaMaritima          String? // línea marítima (ej: MSC, Maersk, CMA CGM)
  fechaEmpaque           DateTime? // fecha de empaque/parque
  lugarTransbordo        String? // si hay transbordo
  fechaTransbordo        DateTime?
  fechaSalida            DateTime? // salida del transporte desde origen
  fechaLlegada           DateTime? // llegada del contenedor a destino
  diasPagoDespuesLlegada Int? // ej: 120 días después de la llegada
  fobTotal               Decimal        @default(0) @db.Decimal(18, 2)
  cifTotal               Decimal        @default(0) @db.Decimal(18, 2)
  die                    Decimal        @default(0) @db.Decimal(18, 2)
  tasaEstadistica        Decimal        @default(0) @db.Decimal(18, 2)
  arancelSim             Decimal        @default(0) @db.Decimal(18, 2)
  iva                    Decimal        @default(0) @db.Decimal(18, 2)
  ivaAdicional           Decimal        @default(0) @db.Decimal(18, 2)
  ganancias              Decimal        @default(0) @db.Decimal(18, 2)
  iibb                   Decimal        @default(0) @db.Decimal(18, 2)
  costoTotal             Decimal        @default(0) @db.Decimal(18, 2)
  asientoId              String?        @unique
  // Fecha en que se realizó el cierre/nacionalización (despacho a plaza).
  // Es la fecha contable del asiento de Nacionalización (NO la del clic).
  fechaCierre            DateTime?
  // Asiento generado al confirmar zona primaria (DEBE 1.1.5.02 MERC. EN
  // TRÁNSITO contra proveedor exterior + facturas locales con momento=ZONA_PRIMARIA).
  asientoZonaPrimariaId  String?        @unique
  // Fecha en que la mercadería entró en Zona Primaria. Es la fecha contable
  // del asiento de Zona Primaria (NO la del clic).
  fechaZonaPrimaria      DateTime?
  depositoDestinoId      String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  proveedor           Proveedor       @relation(fields: [proveedorId], references: [id])
  items               ItemEmbarque[]
  costos              EmbarqueCosto[]
  asiento             Asiento?        @relation("EmbarqueAsientoCierre", fields: [asientoId], references: [id])
  asientoZonaPrimaria Asiento?        @relation("EmbarqueAsientoZP", fields: [asientoZonaPrimariaId], references: [id])
  depositoDestino     Deposito?       @relation(fields: [depositoDestinoId], references: [id])
  pedidoCompra        PedidoCompra?   @relation(fields: [pedidoCompraId], references: [id])
  despachos           Despacho[]
}

// Factura de proveedor local (gastos de nacionalización: despachante,
// operador portuario, fletes, almacenaje, etc.) asociada al embarque.
// Cada factura agrupa N conceptos (gastos) en sus EmbarqueCostoLinea.
// IVA/IIBB/otros son totales a nivel factura — se imputan a las
// cuentas de crédito fiscal contra el proveedor, NO contra cada gasto.
model EmbarqueCosto {
  id               Int           @id @default(autoincrement())
  embarqueId       String
  proveedorId      String
  moneda           Moneda
  tipoCambio       Decimal       @db.Decimal(18, 6)
  facturaNumero    String?
  fechaFactura     DateTime?
  fechaVencimiento DateTime? // auto-calculada de fechaFactura + diasPagoDefault del proveedor; editable
  condicionPago    CondicionPago @default(CUENTA_CORRIENTE)
  // Momento del flujo de importación: ZONA_PRIMARIA (puerto, frete
  // terrestre, op. logístico, gastos línea marítima — antes del despacho)
  // o DESPACHO (despachante, DIA, op. logístico — al nacionalizar).
  momento          MomentoCosto  @default(DESPACHO)
  // Totales fiscales a nivel factura (no por línea):
  iva              Decimal       @default(0) @db.Decimal(18, 2)
  iibb             Decimal       @default(0) @db.Decimal(18, 2)
  otros            Decimal       @default(0) @db.Decimal(18, 2)
  notas            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // FK opcional al despacho que consume esta factura. Sólo seteado para
  // facturas con momento === DESPACHO cuando el embarque tiene N
  // despachos parciales. En flujo monolítico (sin Despacho records) o
  // facturas ZP queda en NULL.
  despachoId String?

  embarque  Embarque             @relation(fields: [embarqueId], references: [id], onDelete: Cascade)
  proveedor Proveedor            @relation(fields: [proveedorId], references: [id])
  despacho  Despacho?            @relation(fields: [despachoId], references: [id], onDelete: SetNull)
  lineas    EmbarqueCostoLinea[]

  @@index([embarqueId])
  @@index([proveedorId])
  @@index([fechaVencimiento])
  @@index([despachoId])
}

// Concepto/gasto individual dentro de una factura: su cuenta contable
// de gasto y monto neto. Sin impuestos a nivel línea (IVA/IIBB van al
// header de la factura).
model EmbarqueCostoLinea {
  id                    Int               @id @default(autoincrement())
  embarqueCostoId       Int
  tipo                  TipoCostoEmbarque
  cuentaContableGastoId Int
  descripcion           String?
  subtotal              Decimal           @db.Decimal(18, 2)

  costo               EmbarqueCosto  @relation(fields: [embarqueCostoId], references: [id], onDelete: Cascade)
  cuentaContableGasto CuentaContable @relation("EmbarqueCostoLineaCuentaGasto", fields: [cuentaContableGastoId], references: [id])

  @@index([embarqueCostoId])
}

model ItemEmbarque {
  id                Int     @id @default(autoincrement())
  embarqueId        String
  productoId        String
  cantidad          Int
  precioUnitarioFob Decimal @db.Decimal(18, 2)
  costoUnitario     Decimal @default(0) @db.Decimal(18, 2)

  embarque         Embarque          @relation(fields: [embarqueId], references: [id], onDelete: Cascade)
  producto         Producto          @relation(fields: [productoId], references: [id])
  movimientosStock MovimientoStock[]
  itemsDespacho    ItemDespacho[]
}

// Despacho aduanero — un embarque puede tener 1..N despachos parciales.
// Cada despacho es la nacionalización de una porción del contenido del
// embarque, con sus propios tributos aduaneros y facturas DESPACHO.
//
// Reglas:
//  - El embarque NO debe tener `asientoId` (cierre monolítico legacy)
//    para crear despachos. Despacho parcial reemplaza el flujo de cierre.
//  - Cada `ItemDespacho` consume `cantidad` del `ItemEmbarque` referenciado.
//    Σ ItemDespacho.cantidad por (embarqueId, productoId) ≤ ItemEmbarque.cantidad.
//  - Al contabilizar: genera asiento (transferencia 1.1.5.02 → 1.1.5.01
//    por la porción correspondiente + tributos + facturas DESPACHO de
//    este despacho) y aplica MovimientoStock por ItemDespacho.
model Despacho {
  id              String         @id @default(uuid())
  codigo          String         @unique // ej: AR-250915-006-D1
  embarqueId      String
  fecha           DateTime
  estado          DespachoEstado @default(BORRADOR)
  numeroOM        String? // Nº de Despacho oficializado (Sufiche/OM34)
  // TC oficializado del despacho (puede diferir del provisorio del embarque).
  tipoCambio      Decimal        @default(1) @db.Decimal(18, 6)
  // Tributos aduaneros de este despacho (en moneda del embarque).
  // Convertidos a ARS con `tipoCambio` al contabilizar.
  die             Decimal        @default(0) @db.Decimal(18, 2)
  tasaEstadistica Decimal        @default(0) @db.Decimal(18, 2)
  arancelSim      Decimal        @default(0) @db.Decimal(18, 2)
  iva             Decimal        @default(0) @db.Decimal(18, 2)
  ivaAdicional    Decimal        @default(0) @db.Decimal(18, 2)
  iibb            Decimal        @default(0) @db.Decimal(18, 2)
  ganancias       Decimal        @default(0) @db.Decimal(18, 2)
  asientoId       String?        @unique
  notas           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  embarque Embarque        @relation(fields: [embarqueId], references: [id], onDelete: Cascade)
  asiento  Asiento?        @relation(fields: [asientoId], references: [id])
  items    ItemDespacho[]
  costos   EmbarqueCosto[]

  @@index([embarqueId])
  @@index([estado])
}

model ItemDespacho {
  id             Int     @id @default(autoincrement())
  despachoId     String
  itemEmbarqueId Int
  cantidad       Int
  // Costo unitario calculado al contabilizar: porción rateada del costo
  // en tránsito del embarque (FOB+origen+ZP) por unidad. Se setea en el
  // contabilizar y queda como referencia.
  costoUnitario  Decimal @default(0) @db.Decimal(18, 2)

  despacho         Despacho          @relation(fields: [despachoId], references: [id], onDelete: Cascade)
  itemEmbarque     ItemEmbarque      @relation(fields: [itemEmbarqueId], references: [id])
  movimientosStock MovimientoStock[]

  @@unique([despachoId, itemEmbarqueId])
  @@index([itemEmbarqueId])
}

model Compra {
  id               String        @id @default(uuid())
  numero           String        @unique
  proveedorId      String
  fecha            DateTime
  fechaVencimiento DateTime?
  condicionPago    CondicionPago @default(CUENTA_CORRIENTE)
  moneda           Moneda
  tipoCambio       Decimal       @default(1) @db.Decimal(18, 6)
  subtotal         Decimal       @db.Decimal(18, 2)
  iva              Decimal       @db.Decimal(18, 2)
  iibb             Decimal       @default(0) @db.Decimal(18, 2)
  otros            Decimal       @default(0) @db.Decimal(18, 2)
  total            Decimal       @db.Decimal(18, 2)
  estado           CompraEstado  @default(BORRADOR)
  asientoId        String?       @unique
  pedidoCompraId   Int?
  notas            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  proveedor    Proveedor     @relation(fields: [proveedorId], references: [id])
  items        ItemCompra[]
  asiento      Asiento?      @relation(fields: [asientoId], references: [id])
  pedidoCompra PedidoCompra? @relation(fields: [pedidoCompraId], references: [id])

  @@index([fechaVencimiento])
  @@index([proveedorId])
}

model ItemCompra {
  id             Int     @id @default(autoincrement())
  compraId       String
  productoId     String
  cantidad       Int
  precioUnitario Decimal @db.Decimal(18, 2)
  subtotal       Decimal @db.Decimal(18, 2)
  iva            Decimal @db.Decimal(18, 2)
  total          Decimal @db.Decimal(18, 2)

  compra   Compra   @relation(fields: [compraId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])
}

// Gasto local — factura ad-hoc de proveedor con N líneas + IVA/IIBB
// header. Sigue la lógica de EmbarqueCosto pero standalone (no ligada
// a un embarque). Para gastos no recurrentes que no encajan ni en
// Compra (mercadería con productoId) ni en GastoFijo (templates
// recurrentes mensuales).
model Gasto {
  id               String        @id @default(uuid())
  numero           String        @unique
  proveedorId      String
  fecha            DateTime
  fechaVencimiento DateTime?
  condicionPago    CondicionPago @default(CUENTA_CORRIENTE)
  moneda           Moneda        @default(ARS)
  tipoCambio       Decimal       @default(1) @db.Decimal(18, 6)
  facturaNumero    String?
  // Totales fiscales a nivel factura (no por línea):
  subtotal         Decimal       @db.Decimal(18, 2)
  iva              Decimal       @default(0) @db.Decimal(18, 2)
  iibb             Decimal       @default(0) @db.Decimal(18, 2)
  otros            Decimal       @default(0) @db.Decimal(18, 2)
  total            Decimal       @db.Decimal(18, 2)
  estado           GastoEstado   @default(BORRADOR)
  asientoId        String?       @unique
  notas            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  proveedor Proveedor    @relation(fields: [proveedorId], references: [id])
  asiento   Asiento?     @relation(fields: [asientoId], references: [id])
  lineas    LineaGasto[]

  @@index([proveedorId])
  @@index([fecha])
  @@index([fechaVencimiento])
  @@index([estado])
}

// Concepto/gasto individual dentro de una factura Gasto. Sin
// impuestos a nivel línea (IVA/IIBB van al header).
model LineaGasto {
  id                    Int     @id @default(autoincrement())
  gastoId               String
  cuentaContableGastoId Int
  descripcion           String
  subtotal              Decimal @db.Decimal(18, 2)

  gasto               Gasto          @relation(fields: [gastoId], references: [id], onDelete: Cascade)
  cuentaContableGasto CuentaContable @relation("LineaGastoCuentaGasto", fields: [cuentaContableGastoId], references: [id])

  @@index([gastoId])
}

// ============================================================
// DATOS MAESTROS
// ============================================================

model Cliente {
  id                       String        @id @default(uuid())
  nombre                   String
  cuit                     String?       @unique
  tipo                     String        @default("minorista")
  tipoCanal                TipoCanal     @default(MINORISTA)
  condicionIva             CondicionIva  @default(RI)
  agenteRetencionIva       Boolean       @default(false)
  agenteRetencionGanancias Boolean       @default(false)
  agenteIibb               Boolean       @default(false)
  direccion                String?
  telefono                 String?
  email                    String?
  estado                   String        @default("activo")
  cuentaContableId         Int?
  diasPagoDefault          Int? // 0 = contado, 30/60/90 = días corridos
  condicionPagoDefault     CondicionPago @default(CONTADO)
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  cuentaContable CuentaContable?           @relation(fields: [cuentaContableId], references: [id])
  ventas         Venta[]
  pedidosVenta   PedidoVenta[]
  extractoLineas LineaExtractoSugerencia[]
  leads          Lead[]
  contactos      Contacto[]
  oportunidades  Oportunidad[]
  actividades    Actividad[]
}

model Proveedor {
  id                    String         @id @default(uuid())
  nombre                String
  cuit                  String?        @unique // opcional para extranjeros (puede ser ID fiscal de su país)
  tipo                  String         @default("otro")
  tipoProveedor         TipoProveedor  @default(MERCADERIA_LOCAL)
  conceptoRG830         ConceptoRG830? // mapping para retención Ganancias
  pais                  String         @default("AR")
  direccion             String?
  telefono              String?
  email                 String?
  estado                String         @default("activo")
  cuentaContableId      Int? // pasivo (cta a pagar) — auto-creada por tipoProveedor
  cuentaGastoContableId Int? // contrapartida de gasto/activo por defecto — auto-fill en embarques/compras
  diasPagoDefault       Int? // 0 = contado, 30/60/90 = días corridos
  condicionPagoDefault  CondicionPago  @default(CONTADO)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  cuentaContable      CuentaContable?           @relation("ProveedorPasivo", fields: [cuentaContableId], references: [id])
  cuentaGastoContable CuentaContable?           @relation("ProveedorGasto", fields: [cuentaGastoContableId], references: [id])
  embarques           Embarque[]
  compras             Compra[]
  costosEmbarque      EmbarqueCosto[]
  pedidosCompra       PedidoCompra[]
  extractoLineas      LineaExtractoSugerencia[]
  gastosFijos         GastoFijo[]
  gastos              Gasto[]
}

model Producto {
  id            String   @id @default(uuid())
  codigo        String   @unique
  nombre        String
  descripcion   String?
  marca         String?
  modelo        String?
  medida        String?
  ncm           String?
  unidad        String   @default("UN")
  diePorcentaje Decimal  @default(0) @db.Decimal(8, 4)
  precioVenta   Decimal  @default(0) @db.Decimal(18, 2)
  costoPromedio Decimal  @default(0) @db.Decimal(18, 2)
  stockActual   Int      @default(0)
  stockMinimo   Int      @default(0)
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  itemsEmbarque     ItemEmbarque[]
  itemsCompra       ItemCompra[]
  itemsVenta        ItemVenta[]
  movimientosStock  MovimientoStock[]
  itemsPedidoCompra ItemPedidoCompra[]
  itemsPedidoVenta  ItemPedidoVenta[]
  stockPorDeposito  StockPorDeposito[]
  transferencias    Transferencia[]
}

model Deposito {
  id        String  @id @default(uuid())
  nombre    String
  direccion String?
  activo    Boolean @default(true)

  movimientos           MovimientoStock[]
  embarques             Embarque[]
  stockPorDeposito      StockPorDeposito[]
  entregas              EntregaVenta[]
  itemsVenta            ItemVenta[]
  transferenciasOrigen  Transferencia[]    @relation("TransferenciaOrigen")
  transferenciasDestino Transferencia[]    @relation("TransferenciaDestino")
}

// ============================================================
// STOCK Y VENTAS
// ============================================================

model MovimientoStock {
  id              String              @id @default(uuid())
  productoId      String
  depositoId      String
  tipo            MovimientoStockTipo
  cantidad        Int
  costoUnitario   Decimal             @db.Decimal(18, 2)
  fecha           DateTime            @default(now())
  // FK opcional al ítem de embarque que originó el ingreso (para poder
  // revertir limpiamente en una anulación). Sólo seteado cuando el
  // movimiento viene de cerrar y contabilizar un embarque (flujo legacy
  // monolítico).
  itemEmbarqueId  Int?
  // FK opcional al ítem de despacho que originó el ingreso. Sólo seteado
  // cuando el movimiento viene de contabilizar un Despacho parcial.
  itemDespachoId  Int?
  // FK opcional al ítem de entrega de venta que originó el egreso (W3).
  itemEntregaId   Int?
  // FK opcional a la transferencia que originó el par origen/destino (W3).
  transferenciaId String?

  producto      Producto       @relation(fields: [productoId], references: [id])
  deposito      Deposito       @relation(fields: [depositoId], references: [id])
  itemEmbarque  ItemEmbarque?  @relation(fields: [itemEmbarqueId], references: [id], onDelete: SetNull)
  itemDespacho  ItemDespacho?  @relation(fields: [itemDespachoId], references: [id], onDelete: SetNull)
  itemEntrega   ItemEntrega?   @relation(fields: [itemEntregaId], references: [id], onDelete: SetNull)
  transferencia Transferencia? @relation(fields: [transferenciaId], references: [id], onDelete: SetNull)

  @@index([productoId])
  @@index([itemEmbarqueId])
  @@index([itemDespachoId])
  @@index([itemEntregaId])
  @@index([transferenciaId])
}

model Venta {
  id               String        @id @default(uuid())
  numero           String        @unique
  clienteId        String
  fecha            DateTime
  fechaVencimiento DateTime?
  condicionPago    CondicionPago @default(CUENTA_CORRIENTE)
  moneda           Moneda
  tipoCambio       Decimal       @default(1) @db.Decimal(18, 6)
  subtotal         Decimal       @db.Decimal(18, 2)
  iva              Decimal       @db.Decimal(18, 2)
  iibb             Decimal       @default(0) @db.Decimal(18, 2)
  otros            Decimal       @default(0) @db.Decimal(18, 2)
  // Flete pagado por nosotros (no se cobra al cliente). No afecta `total`.
  // Reduce el margen neto de la operación y se contabiliza como gasto.
  flete            Decimal       @default(0) @db.Decimal(18, 2)
  total            Decimal       @db.Decimal(18, 2)
  estado           VentaEstado   @default(BORRADOR)
  asientoId        String?       @unique
  pedidoVentaId    Int?
  notas            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  cliente          Cliente          @relation(fields: [clienteId], references: [id])
  asiento          Asiento?         @relation(fields: [asientoId], references: [id])
  items            ItemVenta[]
  pedidoVenta      PedidoVenta?     @relation(fields: [pedidoVentaId], references: [id])
  chequesRecibidos ChequeRecibido[]
  entregas         EntregaVenta[]

  @@index([fechaVencimiento])
  @@index([clienteId])
}

// Cheques de terceros recibidos como medio de cobro de ventas. Quedan
// en cartera (cuenta 1.1.4.20) hasta que se depositen / acrediten en
// el banco. Cada cheque tiene su propia fecha de pago.
enum ChequeRecibidoEstado {
  EN_CARTERA // Recibido — esperando depósito o vencimiento
  DEPOSITADO // En tránsito — depositado pero no acreditado
  ACREDITADO // Acreditado en cuenta bancaria
  RECHAZADO // Rechazado por falta de fondos
  ANULADO // Cancelado / devuelto
}

model ChequeRecibido {
  id             Int                  @id @default(autoincrement())
  ventaId        String?
  numero         String
  // Tipo: ECHEQ (electrónico) o FISICO. ECHEQ tiene echeqId/CMC7.
  tipo           String               @default("FISICO")
  cmc7           String?
  echeqId        String?
  banco          String?
  emisor         String? // razón social/nombre del que emite el cheque
  cuitEmisor     String?
  importe        Decimal              @db.Decimal(18, 2)
  fechaEmision   DateTime
  fechaPago      DateTime // fecha en que se hace efectivo el cheque
  estado         ChequeRecibidoEstado @default(EN_CARTERA)
  asientoCobroId String?              @unique // asiento al acreditar
  notas          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  venta   Venta?   @relation(fields: [ventaId], references: [id])
  asiento Asiento? @relation(fields: [asientoCobroId], references: [id])

  @@index([ventaId])
  @@index([estado])
  @@index([fechaPago])
}

model ItemVenta {
  id             Int     @id @default(autoincrement())
  ventaId        String
  productoId     String
  cantidad       Int
  // Hasta 4 decimales — útil en mayoristas donde redondear el unitario
  // a 2 decimales distorsiona el total final. subtotal/iva/total siguen
  // en 2 decimales (ya redondeado al asentar contabilidad).
  precioUnitario Decimal @db.Decimal(18, 4)
  subtotal       Decimal @db.Decimal(18, 2)
  iva            Decimal @db.Decimal(18, 2)
  total          Decimal @db.Decimal(18, 2)
  // Depósito desde el cual se reserva/entrega este item. Nullable:
  // cuando es null, cae al default global (`getDepositoPorDefecto`),
  // manteniendo retrocompatibilidad con ventas pre-S3.1.
  depositoId     String?

  venta        Venta         @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  producto     Producto      @relation(fields: [productoId], references: [id])
  deposito     Deposito?     @relation(fields: [depositoId], references: [id])
  itemsEntrega ItemEntrega[]

  @@index([depositoId])
}

// ============================================================
// STOCK DUAL (W3): reserva en emisión + baja física en entrega
// ============================================================

// Stock segmentado por (producto, depósito). Reemplaza la noción de
// `Producto.stockActual` global por una visión multi-depósito con
// reserva separada de la cantidad física.
//
// - cantidadFisica:    lo que está realmente en el depósito.
// - cantidadReservada: comprometido en ventas EMITIDAs pendientes de entrega.
// - disponible (derivado): cantidadFisica - cantidadReservada.
// - costoPromedio:     ponderado por depósito (decisión arquitectónica W3 #3).
//
// Mientras `STOCK_DUAL_ENABLED` esté off, este modelo se mantiene en
// paralelo a `Producto.stockActual` (legacy) y se sincroniza en backfill.
model StockPorDeposito {
  id                String   @id @default(uuid())
  productoId        String
  depositoId        String
  cantidadFisica    Int      @default(0)
  cantidadReservada Int      @default(0)
  costoPromedio     Decimal  @default(0) @db.Decimal(18, 2)
  ultimoMovimiento  DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  producto Producto @relation(fields: [productoId], references: [id])
  deposito Deposito @relation(fields: [depositoId], references: [id])

  @@unique([productoId, depositoId])
  @@index([depositoId])
}

// Nota de entrega (remito) de una venta. Una venta EMITIDA puede tener
// 0..N entregas (entregas parciales o completas). La entrega CONFIRMADA
// es el momento en que se da de baja el stock físico y se genera el
// asiento contable de baja (DEBE 1.1.5.02 MercaderiasAEntregar /
// HABER 1.1.5.01 Mercaderias).
model EntregaVenta {
  id          String        @id @default(uuid())
  numero      String        @unique
  ventaId     String
  depositoId  String
  fecha       DateTime
  estado      EntregaEstado @default(BORRADOR)
  asientoId   String?       @unique
  observacion String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  venta    Venta         @relation(fields: [ventaId], references: [id])
  deposito Deposito      @relation(fields: [depositoId], references: [id])
  asiento  Asiento?      @relation(fields: [asientoId], references: [id])
  items    ItemEntrega[]

  @@index([ventaId])
  @@index([estado])
}

// Línea de una entrega: vincula 1..1 con un ItemVenta y captura la
// `cantidad` entregada en este remito (puede ser parcial respecto al
// item de venta original) y el `costoUnitario` snapshot del costoPromedio
// del depósito en el momento de la confirmación (necesario para CMV).
model ItemEntrega {
  id            Int     @id @default(autoincrement())
  entregaId     String
  itemVentaId   Int
  cantidad      Int
  costoUnitario Decimal @default(0) @db.Decimal(18, 2)

  entrega          EntregaVenta      @relation(fields: [entregaId], references: [id], onDelete: Cascade)
  itemVenta        ItemVenta         @relation(fields: [itemVentaId], references: [id])
  movimientosStock MovimientoStock[]

  @@index([itemVentaId])
}

// Transferencia entre depósitos. Genera dos `MovimientoStock` tipo
// TRANSFERENCIA (uno -cantidad en origen, otro +cantidad en destino).
// No genera asiento contable (movimiento interno de inventario).
model Transferencia {
  id                String              @id @default(uuid())
  numero            String              @unique
  productoId        String
  depositoOrigenId  String
  depositoDestinoId String
  cantidad          Int
  fecha             DateTime
  estado            TransferenciaEstado @default(CONFIRMADA)
  observacion       String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  producto         Producto          @relation(fields: [productoId], references: [id])
  origen           Deposito          @relation("TransferenciaOrigen", fields: [depositoOrigenId], references: [id])
  destino          Deposito          @relation("TransferenciaDestino", fields: [depositoDestinoId], references: [id])
  movimientosStock MovimientoStock[]

  @@index([productoId])
  @@index([fecha])
}

// ============================================================
// PEDIDOS (Órdenes de Compra y de Venta)
// ============================================================

model PedidoCompra {
  id            Int          @id @default(autoincrement())
  numero        String       @unique
  proveedorId   String
  fecha         DateTime
  fechaPrevista DateTime?
  moneda        Moneda
  tipoCambio    Decimal      @default(1) @db.Decimal(18, 6)
  estado        PedidoEstado @default(BORRADOR)
  observaciones String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  proveedor Proveedor          @relation(fields: [proveedorId], references: [id])
  items     ItemPedidoCompra[]
  compras   Compra[]
  embarques Embarque[]

  @@index([proveedorId])
  @@index([estado])
}

model ItemPedidoCompra {
  id             Int     @id @default(autoincrement())
  pedidoCompraId Int
  productoId     String
  cantidad       Int
  precioUnitario Decimal @db.Decimal(18, 2)

  pedido   PedidoCompra @relation(fields: [pedidoCompraId], references: [id], onDelete: Cascade)
  producto Producto     @relation(fields: [productoId], references: [id])

  @@index([pedidoCompraId])
}

model PedidoVenta {
  id            Int          @id @default(autoincrement())
  numero        String       @unique
  clienteId     String
  fecha         DateTime
  fechaPrevista DateTime?
  moneda        Moneda
  tipoCambio    Decimal      @default(1) @db.Decimal(18, 6)
  estado        PedidoEstado @default(BORRADOR)
  observaciones String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  cliente Cliente           @relation(fields: [clienteId], references: [id])
  items   ItemPedidoVenta[]
  ventas  Venta[]

  @@index([clienteId])
  @@index([estado])
}

model ItemPedidoVenta {
  id             Int     @id @default(autoincrement())
  pedidoVentaId  Int
  productoId     String
  cantidad       Int
  precioUnitario Decimal @db.Decimal(18, 2)

  pedido   PedidoVenta @relation(fields: [pedidoVentaId], references: [id], onDelete: Cascade)
  producto Producto    @relation(fields: [productoId], references: [id])

  @@index([pedidoVentaId])
}

// ============================================================
// AUXILIARES
// ============================================================

model JurisdiccionIIBB {
  id       Int     @id @default(autoincrement())
  codigo   String  @unique
  nombre   String
  alicuota Decimal @db.Decimal(8, 4)
}

model IndiceIPC {
  id      Int     @id @default(autoincrement())
  periodo String  @unique
  valor   Decimal @db.Decimal(15, 4)
  fuente  String
}

model AuditLog {
  id              Int         @id @default(autoincrement())
  tabla           String
  registroId      String
  accion          AuditAccion
  datosAnteriores Json?
  datosNuevos     Json?
  usuarioId       String
  fecha           DateTime    @default(now())

  usuario User @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@index([tabla, registroId])
}

// ============================================================
// GASTOS FIJOS (alquiler, contador, internet, etc — recurrentes)
// ============================================================

// Template de gasto recurrente. El usuario lo crea una vez con monto
// base y luego "registra" cada mes — eso genera un Asiento contable
// (DEBE gasto / HABER proveedor) y queda como cuenta a pagar hasta
// que se pague vía Tesorería.
model GastoFijo {
  id                    Int      @id @default(autoincrement())
  descripcion           String
  proveedorId           String
  // Override del default del proveedor (si vacío, usa proveedor.cuentaGastoContableId
  // o el fallback por tipoProveedor).
  cuentaGastoContableId Int?
  moneda                Moneda   @default(ARS)
  montoNeto             Decimal  @db.Decimal(18, 2)
  ivaPorcentaje         Decimal  @default(21) @db.Decimal(5, 2)
  iibbPorcentaje        Decimal  @default(0) @db.Decimal(5, 2)
  // Día del mes en que vence (1-28 para evitar feb). Opcional.
  diaVencimiento        Int?
  activo                Boolean  @default(true)
  notas                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  proveedor           Proveedor           @relation(fields: [proveedorId], references: [id])
  cuentaGastoContable CuentaContable?     @relation(fields: [cuentaGastoContableId], references: [id])
  registros           GastoFijoRegistro[]

  @@index([proveedorId])
  @@index([activo])
}

// Registro mensual de un GastoFijo — apunta al asiento generado.
// Único por (gastoFijoId, año, mes) para prevenir doble registro.
model GastoFijoRegistro {
  id           Int      @id @default(autoincrement())
  gastoFijoId  Int
  periodoYear  Int
  periodoMonth Int
  fecha        DateTime
  tipoCambio   Decimal  @default(1) @db.Decimal(18, 6)
  montoNeto    Decimal  @db.Decimal(18, 2)
  iva          Decimal  @db.Decimal(18, 2)
  iibb         Decimal  @db.Decimal(18, 2)
  total        Decimal  @db.Decimal(18, 2)
  asientoId    String?  @unique
  createdAt    DateTime @default(now())

  gastoFijo GastoFijo @relation(fields: [gastoFijoId], references: [id], onDelete: Cascade)
  asiento   Asiento?  @relation(fields: [asientoId], references: [id])

  @@unique([gastoFijoId, periodoYear, periodoMonth])
  @@index([periodoYear, periodoMonth])
}

// ============================================================
// IMPORTACIÓN DE EXTRACTOS BANCARIOS (con sugerencias IA)
// ============================================================

enum ImportacionExtractoStatus {
  PENDIENTE
  PARCIAL
  COMPLETADO
  CANCELADO
}

enum LineaExtractoStatus {
  PENDIENTE
  APROBADA
  RECHAZADA
  IGNORADA
}

model ImportacionExtracto {
  id               String                    @id @default(uuid())
  cuentaBancariaId String
  periodoYear      Int
  periodoMonth     Int
  saldoInicial     Decimal                   @db.Decimal(18, 2)
  saldoFinal       Decimal                   @db.Decimal(18, 2)
  archivoNombre    String?
  status           ImportacionExtractoStatus @default(PENDIENTE)
  totalLineas      Int                       @default(0)
  lineasAprobadas  Int                       @default(0)
  modeloIA         String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  cuentaBancaria CuentaBancaria            @relation(fields: [cuentaBancariaId], references: [id])
  lineas         LineaExtractoSugerencia[]

  @@unique([cuentaBancariaId, periodoYear, periodoMonth])
  @@index([status])
}

model LineaExtractoSugerencia {
  id              String   @id @default(uuid())
  importacionId   String
  ordenLinea      Int
  fecha           DateTime
  descripcion     String
  comprobante     String?
  referenciaBanco String?
  monto           Decimal  @db.Decimal(18, 2)
  saldoExtracto   Decimal? @db.Decimal(18, 2)

  cuentaSugeridaId    Int?
  proveedorSugeridoId String?
  clienteSugeridoId   String?
  descripcionAsiento  String?
  confianza           String?
  razonSugerencia     String?

  status       LineaExtractoStatus @default(PENDIENTE)
  movimientoId String?             @unique
  notas        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  importacion    ImportacionExtracto  @relation(fields: [importacionId], references: [id], onDelete: Cascade)
  cuentaSugerida CuentaContable?      @relation(fields: [cuentaSugeridaId], references: [id])
  proveedor      Proveedor?           @relation(fields: [proveedorSugeridoId], references: [id])
  cliente        Cliente?             @relation(fields: [clienteSugeridoId], references: [id])
  movimiento     MovimientoTesoreria? @relation(fields: [movimientoId], references: [id])

  @@index([importacionId, ordenLinea])
  @@index([status])
}

// Cotización USD (1 USD = `valor` ARS). Usada para mostrar reportes en USD.
// Se elige el TC vigente más reciente cuya `fecha` sea <= la fecha de corte del reporte.
model Cotizacion {
  id        Int      @id @default(autoincrement())
  fecha     DateTime @unique @db.Date
  valor     Decimal  @db.Decimal(18, 6)
  fuente    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fecha])
}

// ============================================================
// CRM (W4) — Lead → Pipeline → Cliente, contactos, actividades, scoring
// ============================================================

enum LeadFuente {
  ORGANICO
  REFERIDO
  EVENTO
  ANUNCIO
  LINKEDIN
  MERCADOLIBRE
  FERIA
  OTRO
}

enum LeadEstado {
  NUEVO
  CONTACTADO
  CALIFICADO
  DESCALIFICADO
  CONVERTIDO
}

enum OportunidadEstado {
  ABIERTA
  GANADA
  PERDIDA
  EN_PAUSA
}

enum ActividadTipo {
  LLAMADA
  EMAIL
  REUNION
  NOTA
  TAREA
  WHATSAPP
}

model Lead {
  id        String     @id @default(uuid())
  nombre    String
  empresa   String?
  cuit      String?
  email     String?
  telefono  String?
  fuente    LeadFuente @default(ORGANICO)
  estado    LeadEstado @default(NUEVO)
  score     Int        @default(0)
  ownerId   String
  notas     String?
  clienteId String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  owner         User          @relation(fields: [ownerId], references: [id])
  cliente       Cliente?      @relation(fields: [clienteId], references: [id])
  contactos     Contacto[]
  actividades   Actividad[]
  oportunidades Oportunidad[]

  @@index([ownerId])
  @@index([estado])
  @@index([clienteId])
}

model Contacto {
  id          String   @id @default(uuid())
  nombre      String
  cargo       String?
  email       String?
  telefono    String?
  esPrincipal Boolean  @default(false)
  leadId      String?
  clienteId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lead    Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  cliente Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([clienteId])
}

model PipelineStage {
  id        String  @id @default(uuid())
  nombre    String
  orden     Int
  esGanada  Boolean @default(false)
  esPerdida Boolean @default(false)
  activo    Boolean @default(true)

  oportunidades Oportunidad[]

  @@unique([orden])
}

model Oportunidad {
  id             String            @id @default(uuid())
  numero         String            @unique
  titulo         String
  monto          Decimal           @db.Decimal(18, 2)
  moneda         Moneda            @default(USD)
  stageId        String
  probabilidad   Int               @default(50)
  cierreEstimado DateTime?
  estado         OportunidadEstado @default(ABIERTA)
  leadId         String?
  clienteId      String?
  ownerId        String
  notas          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  stage       PipelineStage @relation(fields: [stageId], references: [id])
  lead        Lead?         @relation(fields: [leadId], references: [id])
  cliente     Cliente?      @relation(fields: [clienteId], references: [id])
  owner       User          @relation(fields: [ownerId], references: [id])
  actividades Actividad[]

  @@index([stageId])
  @@index([ownerId])
  @@index([estado])
  @@index([leadId])
  @@index([clienteId])
}

model Actividad {
  id              String        @id @default(uuid())
  tipo            ActividadTipo
  contenido       String
  fechaProgramada DateTime?
  completada      Boolean       @default(false)
  fechaCompletada DateTime?
  ownerId         String
  leadId          String?
  clienteId       String?
  oportunidadId   String?
  sentimiento     Decimal?      @db.Decimal(3, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  owner       User         @relation(fields: [ownerId], references: [id])
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  cliente     Cliente?     @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  oportunidad Oportunidad? @relation(fields: [oportunidadId], references: [id], onDelete: SetNull)

  @@index([ownerId, completada])
  @@index([leadId])
  @@index([clienteId])
  @@index([oportunidadId])
}

model EmailTemplate {
  id        String   @id @default(uuid())
  nombre    String
  asunto    String
  cuerpo    String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScoringRule {
  id        String   @id @default(uuid())
  nombre    String
  campo     String
  operador  String
  valor     String
  puntos    Int
  activa    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
