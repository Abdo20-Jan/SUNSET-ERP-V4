// Sunset Tires ERP v4 — Prisma schema
// Fonte da verdade: vault Obsidian `sunset-tires-brain` (acessado exclusivamente via MCP).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  ADMIN
  USER
}

enum CuentaTipo {
  SINTETICA
  ANALITICA
}

enum CuentaCategoria {
  ACTIVO
  PASIVO
  PATRIMONIO
  INGRESO
  EGRESO
}

enum PeriodoEstado {
  ABIERTO
  CERRADO
}

enum AsientoEstado {
  BORRADOR
  CONTABILIZADO
  ANULADO
}

enum AsientoOrigen {
  MANUAL
  TESORERIA
  COMEX
  AJUSTE
}

enum TipoCuentaBancaria {
  CUENTA_CORRIENTE
  CAJA_AHORRO
  CAJA_CHICA
}

enum Moneda {
  ARS
  USD
}

enum MovimientoTesoreriaTipo {
  PAGO
  COBRO
  TRANSFERENCIA
}

enum PrestamoClasificacion {
  CORTO_PLAZO
  LARGO_PLAZO
}

enum EmbarqueEstado {
  BORRADOR
  EN_TRANSITO
  EN_PUERTO
  EN_ADUANA
  DESPACHADO
  EN_DEPOSITO
  CERRADO
}

enum TipoCostoEmbarque {
  FLETE_INTERNACIONAL
  FLETE_NACIONAL
  SEGURO_MARITIMO
  GASTOS_PORTUARIOS
  HONORARIOS_DESPACHANTE
  OPERADOR_LOGISTICO
  ALMACENAJE
  DEVOLUCION_CONTENEDOR
  AGENTE_DE_CARGAS
  GASTOS_LOCALES
  GASTOS_EXTRAS
}

// Incoterms 2020 (cláusulas de comercio internacional).
// Determinan quién paga qué y cuándo se transfiere el riesgo.
enum Incoterm {
  EXW // Ex Works — comprador asume todo desde la fábrica
  FCA // Free Carrier — vendedor entrega al transportista designado
  FAS // Free Alongside Ship — costado del buque, puerto origen
  FOB // Free on Board — a bordo del buque, puerto origen
  CFR // Cost and Freight — incluye flete, no seguro
  CIF // Cost, Insurance and Freight — incluye flete + seguro
  CPT // Carriage Paid To
  CIP // Carriage and Insurance Paid To
  DAP // Delivered at Place
  DPU // Delivered at Place Unloaded
  DDP // Delivered Duty Paid — vendedor asume todo
}

// Estado de pedidos de compra/venta — flujo borrador hasta cierre.
enum PedidoEstado {
  BORRADOR
  ENVIADO // Pedido emitido al proveedor / enviado al cliente
  CONFIRMADO // Confirmado por la contraparte
  PARCIAL // Facturado/recibido parcialmente
  COMPLETADO // Totalmente facturado/recibido
  CANCELADO
}

// Condición de pago estándar — cómo se paga la factura.
enum CondicionPago {
  CONTADO
  TRANSFERENCIA
  CHEQUE
  TARJETA
  CUENTA_CORRIENTE
  OTRO
}

enum CompraEstado {
  BORRADOR
  EMITIDA
  RECIBIDA
  CANCELADA
}

enum VentaEstado {
  BORRADOR
  EMITIDA
  CANCELADA
}

enum MovimientoStockTipo {
  INGRESO
  EGRESO
  AJUSTE
  TRANSFERENCIA
}

enum CondicionIva {
  RI
  MONOTRIBUTO
  EXENTO
  CONSUMIDOR_FINAL
  EXTERIOR
}

enum TipoCanal {
  MAYORISTA
  MINORISTA
  REVENDEDOR_GOMERIA
  TRANSPORTISTA
  GRANDE_CUENTA
  EXTERIOR
  CONSUMIDOR_FINAL
}

enum TipoProveedor {
  MERCADERIA_LOCAL
  DESPACHANTE
  LOGISTICA
  ALMACENAJE
  SERVICIOS_PROFESIONALES
  ALQUILERES
  IT_SOFTWARE
  GASTOS_PORTUARIOS
  MARKETING
  OTRO
  MERCADERIA_EXTERIOR
  SERVICIOS_EXTERIOR
}

enum ConceptoRG830 {
  BIENES_DE_CAMBIO
  HONORARIOS
  ALQUILERES
  SERVICIOS_GENERALES
  LOCACIONES_SERVICIOS
}

enum AuditAccion {
  CREATE
  UPDATE
  DELETE
}

// ============================================================
// AUTENTICACIÓN
// ============================================================

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  nombre       String
  role         Role     @default(USER)
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs AuditLog[]
}

// ============================================================
// CONTABILIDAD
// ============================================================

model CuentaContable {
  id          Int             @id @default(autoincrement())
  codigo      String          @unique
  nombre      String
  tipo        CuentaTipo
  categoria   CuentaCategoria
  nivel       Int
  padreCodigo String?
  activa      Boolean         @default(true)

  padre CuentaContable?  @relation("CuentaPadre", fields: [padreCodigo], references: [codigo])
  hijos CuentaContable[] @relation("CuentaPadre")

  lineas              LineaAsiento[]
  cuentasBancarias    CuentaBancaria[]
  clientes            Cliente[]
  proveedores         Proveedor[]               @relation("ProveedorPasivo")
  proveedoresGasto    Proveedor[]               @relation("ProveedorGasto")
  prestamos           PrestamoExterno[]
  movimientos         MovimientoTesoreria[]
  embarqueCostoLineas EmbarqueCostoLinea[]      @relation("EmbarqueCostoLineaCuentaGasto")
  extractoLineas      LineaExtractoSugerencia[]
  gastosFijos         GastoFijo[]
}

model PeriodoContable {
  id          Int           @id @default(autoincrement())
  codigo      String        @unique
  nombre      String
  fechaInicio DateTime
  fechaFin    DateTime
  estado      PeriodoEstado @default(ABIERTO)

  asientos Asiento[]
}

model Asiento {
  id          String        @id @default(uuid())
  numero      Int
  fecha       DateTime
  descripcion String
  estado      AsientoEstado @default(BORRADOR)
  totalDebe   Decimal       @db.Decimal(18, 2)
  totalHaber  Decimal       @db.Decimal(18, 2)
  origen      AsientoOrigen
  moneda      Moneda        @default(ARS)
  tipoCambio  Decimal       @default(1) @db.Decimal(18, 6)
  periodoId   Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  periodo             PeriodoContable      @relation(fields: [periodoId], references: [id])
  lineas              LineaAsiento[]
  movimiento          MovimientoTesoreria?
  prestamo            PrestamoExterno?
  venta               Venta?
  compra              Compra?
  embarque            Embarque?
  gastoFijoRegistro   GastoFijoRegistro?
  chequeRecibidoCobro ChequeRecibido?

  @@unique([periodoId, numero])
  @@index([fecha])
  @@index([estado])
}

model LineaAsiento {
  id          Int     @id @default(autoincrement())
  asientoId   String
  cuentaId    Int
  debe        Decimal @default(0) @db.Decimal(18, 2)
  haber       Decimal @default(0) @db.Decimal(18, 2)
  descripcion String?

  asiento Asiento        @relation(fields: [asientoId], references: [id], onDelete: Restrict)
  cuenta  CuentaContable @relation(fields: [cuentaId], references: [id])

  @@index([cuentaId])
}

// ============================================================
// TESORERÍA
// ============================================================

model CuentaBancaria {
  id               String             @id @default(uuid())
  banco            String
  tipo             TipoCuentaBancaria
  moneda           Moneda
  numero           String?
  cbu              String?
  alias            String?
  cuentaContableId Int
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  cuentaContable CuentaContable        @relation(fields: [cuentaContableId], references: [id])
  movimientos    MovimientoTesoreria[]
  prestamos      PrestamoExterno[]
  importaciones  ImportacionExtracto[]
}

model MovimientoTesoreria {
  id               String                  @id @default(uuid())
  tipo             MovimientoTesoreriaTipo
  cuentaBancariaId String
  monto            Decimal                 @db.Decimal(18, 2)
  moneda           Moneda
  tipoCambio       Decimal                 @db.Decimal(18, 6)
  fecha            DateTime
  cuentaContableId Int
  asientoId        String?                 @unique
  descripcion      String?
  comprobante      String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  cuentaBancaria CuentaBancaria           @relation(fields: [cuentaBancariaId], references: [id])
  cuentaContable CuentaContable           @relation(fields: [cuentaContableId], references: [id])
  asiento        Asiento?                 @relation(fields: [asientoId], references: [id])
  lineaExtracto  LineaExtractoSugerencia?

  @@index([fecha])
}

model PrestamoExterno {
  id               String                @id @default(uuid())
  prestamista      String
  cuentaBancariaId String
  moneda           Moneda
  principal        Decimal               @db.Decimal(18, 2)
  tipoCambio       Decimal               @db.Decimal(18, 6)
  clasificacion    PrestamoClasificacion
  cuentaContableId Int
  asientoId        String?               @unique
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  cuentaBancaria CuentaBancaria @relation(fields: [cuentaBancariaId], references: [id])
  cuentaContable CuentaContable @relation(fields: [cuentaContableId], references: [id])
  asiento        Asiento?       @relation(fields: [asientoId], references: [id])
}

// ============================================================
// COMEX
// ============================================================

model Embarque {
  id                     String         @id @default(uuid())
  codigo                 String         @unique
  proveedorId            String
  estado                 EmbarqueEstado @default(BORRADOR)
  moneda                 Moneda
  tipoCambio             Decimal        @db.Decimal(18, 6)
  incoterm               Incoterm?
  lugarIncoterm          String? // ej: "Shanghai", "Buenos Aires"
  pedidoCompraId         Int? // link opcional a OC que originó el embarque
  // Datos de transporte
  nombreBuque            String? // nombre del navío (ej: MSC GAYANE)
  lineaMaritima          String? // línea marítima (ej: MSC, Maersk, CMA CGM)
  fechaEmpaque           DateTime? // fecha de empaque/parque
  lugarTransbordo        String? // si hay transbordo
  fechaTransbordo        DateTime?
  fechaSalida            DateTime? // salida del transporte desde origen
  fechaLlegada           DateTime? // llegada del contenedor a destino
  diasPagoDespuesLlegada Int? // ej: 120 días después de la llegada
  fobTotal               Decimal        @default(0) @db.Decimal(18, 2)
  cifTotal               Decimal        @default(0) @db.Decimal(18, 2)
  die                    Decimal        @default(0) @db.Decimal(18, 2)
  tasaEstadistica        Decimal        @default(0) @db.Decimal(18, 2)
  arancelSim             Decimal        @default(0) @db.Decimal(18, 2)
  iva                    Decimal        @default(0) @db.Decimal(18, 2)
  ivaAdicional           Decimal        @default(0) @db.Decimal(18, 2)
  ganancias              Decimal        @default(0) @db.Decimal(18, 2)
  iibb                   Decimal        @default(0) @db.Decimal(18, 2)
  costoTotal             Decimal        @default(0) @db.Decimal(18, 2)
  asientoId              String?        @unique
  depositoDestinoId      String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  proveedor       Proveedor       @relation(fields: [proveedorId], references: [id])
  items           ItemEmbarque[]
  costos          EmbarqueCosto[]
  asiento         Asiento?        @relation(fields: [asientoId], references: [id])
  depositoDestino Deposito?       @relation(fields: [depositoDestinoId], references: [id])
  pedidoCompra    PedidoCompra?   @relation(fields: [pedidoCompraId], references: [id])
}

// Factura de proveedor local (gastos de nacionalización: despachante,
// operador portuario, fletes, almacenaje, etc.) asociada al embarque.
// Cada factura agrupa N conceptos (gastos) en sus EmbarqueCostoLinea.
// IVA/IIBB/otros son totales a nivel factura — se imputan a las
// cuentas de crédito fiscal contra el proveedor, NO contra cada gasto.
model EmbarqueCosto {
  id               Int           @id @default(autoincrement())
  embarqueId       String
  proveedorId      String
  moneda           Moneda
  tipoCambio       Decimal       @db.Decimal(18, 6)
  facturaNumero    String?
  fechaFactura     DateTime?
  fechaVencimiento DateTime? // auto-calculada de fechaFactura + diasPagoDefault del proveedor; editable
  condicionPago    CondicionPago @default(CUENTA_CORRIENTE)
  // Totales fiscales a nivel factura (no por línea):
  iva              Decimal       @default(0) @db.Decimal(18, 2)
  iibb             Decimal       @default(0) @db.Decimal(18, 2)
  otros            Decimal       @default(0) @db.Decimal(18, 2)
  notas            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  embarque  Embarque             @relation(fields: [embarqueId], references: [id], onDelete: Cascade)
  proveedor Proveedor            @relation(fields: [proveedorId], references: [id])
  lineas    EmbarqueCostoLinea[]

  @@index([embarqueId])
  @@index([proveedorId])
  @@index([fechaVencimiento])
}

// Concepto/gasto individual dentro de una factura: su cuenta contable
// de gasto y monto neto. Sin impuestos a nivel línea (IVA/IIBB van al
// header de la factura).
model EmbarqueCostoLinea {
  id                    Int               @id @default(autoincrement())
  embarqueCostoId       Int
  tipo                  TipoCostoEmbarque
  cuentaContableGastoId Int
  descripcion           String?
  subtotal              Decimal           @db.Decimal(18, 2)

  costo               EmbarqueCosto  @relation(fields: [embarqueCostoId], references: [id], onDelete: Cascade)
  cuentaContableGasto CuentaContable @relation("EmbarqueCostoLineaCuentaGasto", fields: [cuentaContableGastoId], references: [id])

  @@index([embarqueCostoId])
}

model ItemEmbarque {
  id                Int     @id @default(autoincrement())
  embarqueId        String
  productoId        String
  cantidad          Int
  precioUnitarioFob Decimal @db.Decimal(18, 2)
  costoUnitario     Decimal @default(0) @db.Decimal(18, 2)

  embarque Embarque @relation(fields: [embarqueId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])
}

model Compra {
  id               String        @id @default(uuid())
  numero           String        @unique
  proveedorId      String
  fecha            DateTime
  fechaVencimiento DateTime?
  condicionPago    CondicionPago @default(CUENTA_CORRIENTE)
  moneda           Moneda
  tipoCambio       Decimal       @default(1) @db.Decimal(18, 6)
  subtotal         Decimal       @db.Decimal(18, 2)
  iva              Decimal       @db.Decimal(18, 2)
  iibb             Decimal       @default(0) @db.Decimal(18, 2)
  otros            Decimal       @default(0) @db.Decimal(18, 2)
  total            Decimal       @db.Decimal(18, 2)
  estado           CompraEstado  @default(BORRADOR)
  asientoId        String?       @unique
  pedidoCompraId   Int?
  notas            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  proveedor    Proveedor     @relation(fields: [proveedorId], references: [id])
  items        ItemCompra[]
  asiento      Asiento?      @relation(fields: [asientoId], references: [id])
  pedidoCompra PedidoCompra? @relation(fields: [pedidoCompraId], references: [id])

  @@index([fechaVencimiento])
  @@index([proveedorId])
}

model ItemCompra {
  id             Int     @id @default(autoincrement())
  compraId       String
  productoId     String
  cantidad       Int
  precioUnitario Decimal @db.Decimal(18, 2)
  subtotal       Decimal @db.Decimal(18, 2)
  iva            Decimal @db.Decimal(18, 2)
  total          Decimal @db.Decimal(18, 2)

  compra   Compra   @relation(fields: [compraId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])
}

// ============================================================
// DATOS MAESTROS
// ============================================================

model Cliente {
  id                       String        @id @default(uuid())
  nombre                   String
  cuit                     String?       @unique
  tipo                     String        @default("minorista")
  tipoCanal                TipoCanal     @default(MINORISTA)
  condicionIva             CondicionIva  @default(RI)
  agenteRetencionIva       Boolean       @default(false)
  agenteRetencionGanancias Boolean       @default(false)
  agenteIibb               Boolean       @default(false)
  direccion                String?
  telefono                 String?
  email                    String?
  estado                   String        @default("activo")
  cuentaContableId         Int?
  diasPagoDefault          Int? // 0 = contado, 30/60/90 = días corridos
  condicionPagoDefault     CondicionPago @default(CONTADO)
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  cuentaContable CuentaContable?           @relation(fields: [cuentaContableId], references: [id])
  ventas         Venta[]
  pedidosVenta   PedidoVenta[]
  extractoLineas LineaExtractoSugerencia[]
}

model Proveedor {
  id                    String         @id @default(uuid())
  nombre                String
  cuit                  String?        @unique // opcional para extranjeros (puede ser ID fiscal de su país)
  tipo                  String         @default("otro")
  tipoProveedor         TipoProveedor  @default(MERCADERIA_LOCAL)
  conceptoRG830         ConceptoRG830? // mapping para retención Ganancias
  pais                  String         @default("AR")
  direccion             String?
  telefono              String?
  email                 String?
  estado                String         @default("activo")
  cuentaContableId      Int? // pasivo (cta a pagar) — auto-creada por tipoProveedor
  cuentaGastoContableId Int? // contrapartida de gasto/activo por defecto — auto-fill en embarques/compras
  diasPagoDefault       Int? // 0 = contado, 30/60/90 = días corridos
  condicionPagoDefault  CondicionPago  @default(CONTADO)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  cuentaContable      CuentaContable?           @relation("ProveedorPasivo", fields: [cuentaContableId], references: [id])
  cuentaGastoContable CuentaContable?           @relation("ProveedorGasto", fields: [cuentaGastoContableId], references: [id])
  embarques           Embarque[]
  compras             Compra[]
  costosEmbarque      EmbarqueCosto[]
  pedidosCompra       PedidoCompra[]
  extractoLineas      LineaExtractoSugerencia[]
  gastosFijos         GastoFijo[]
}

model Producto {
  id            String   @id @default(uuid())
  codigo        String   @unique
  nombre        String
  descripcion   String?
  marca         String?
  modelo        String?
  medida        String?
  ncm           String?
  unidad        String   @default("UN")
  diePorcentaje Decimal  @default(0) @db.Decimal(8, 4)
  precioVenta   Decimal  @default(0) @db.Decimal(18, 2)
  costoPromedio Decimal  @default(0) @db.Decimal(18, 2)
  stockActual   Int      @default(0)
  stockMinimo   Int      @default(0)
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  itemsEmbarque     ItemEmbarque[]
  itemsCompra       ItemCompra[]
  itemsVenta        ItemVenta[]
  movimientosStock  MovimientoStock[]
  itemsPedidoCompra ItemPedidoCompra[]
  itemsPedidoVenta  ItemPedidoVenta[]
}

model Deposito {
  id        String  @id @default(uuid())
  nombre    String
  direccion String?
  activo    Boolean @default(true)

  movimientos MovimientoStock[]
  embarques   Embarque[]
}

// ============================================================
// STOCK Y VENTAS
// ============================================================

model MovimientoStock {
  id            String              @id @default(uuid())
  productoId    String
  depositoId    String
  tipo          MovimientoStockTipo
  cantidad      Int
  costoUnitario Decimal             @db.Decimal(18, 2)
  fecha         DateTime            @default(now())

  producto Producto @relation(fields: [productoId], references: [id])
  deposito Deposito @relation(fields: [depositoId], references: [id])

  @@index([productoId])
}

model Venta {
  id               String        @id @default(uuid())
  numero           String        @unique
  clienteId        String
  fecha            DateTime
  fechaVencimiento DateTime?
  condicionPago    CondicionPago @default(CUENTA_CORRIENTE)
  moneda           Moneda
  tipoCambio       Decimal       @default(1) @db.Decimal(18, 6)
  subtotal         Decimal       @db.Decimal(18, 2)
  iva              Decimal       @db.Decimal(18, 2)
  iibb             Decimal       @default(0) @db.Decimal(18, 2)
  otros            Decimal       @default(0) @db.Decimal(18, 2)
  total            Decimal       @db.Decimal(18, 2)
  estado           VentaEstado   @default(BORRADOR)
  asientoId        String?       @unique
  pedidoVentaId    Int?
  notas            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  cliente          Cliente          @relation(fields: [clienteId], references: [id])
  asiento          Asiento?         @relation(fields: [asientoId], references: [id])
  items            ItemVenta[]
  pedidoVenta      PedidoVenta?     @relation(fields: [pedidoVentaId], references: [id])
  chequesRecibidos ChequeRecibido[]

  @@index([fechaVencimiento])
  @@index([clienteId])
}

// Cheques de terceros recibidos como medio de cobro de ventas. Quedan
// en cartera (cuenta 1.1.4.20) hasta que se depositen / acrediten en
// el banco. Cada cheque tiene su propia fecha de pago.
enum ChequeRecibidoEstado {
  EN_CARTERA // Recibido — esperando depósito o vencimiento
  DEPOSITADO // En tránsito — depositado pero no acreditado
  ACREDITADO // Acreditado en cuenta bancaria
  RECHAZADO // Rechazado por falta de fondos
  ANULADO // Cancelado / devuelto
}

model ChequeRecibido {
  id             Int                  @id @default(autoincrement())
  ventaId        String?
  numero         String
  // Tipo: ECHEQ (electrónico) o FISICO. ECHEQ tiene echeqId/CMC7.
  tipo           String               @default("FISICO")
  cmc7           String?
  echeqId        String?
  banco          String?
  emisor         String? // razón social/nombre del que emite el cheque
  cuitEmisor     String?
  importe        Decimal              @db.Decimal(18, 2)
  fechaEmision   DateTime
  fechaPago      DateTime // fecha en que se hace efectivo el cheque
  estado         ChequeRecibidoEstado @default(EN_CARTERA)
  asientoCobroId String?              @unique // asiento al acreditar
  notas          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  venta   Venta?   @relation(fields: [ventaId], references: [id])
  asiento Asiento? @relation(fields: [asientoCobroId], references: [id])

  @@index([ventaId])
  @@index([estado])
  @@index([fechaPago])
}

model ItemVenta {
  id             Int     @id @default(autoincrement())
  ventaId        String
  productoId     String
  cantidad       Int
  // Hasta 4 decimales — útil en mayoristas donde redondear el unitario
  // a 2 decimales distorsiona el total final. subtotal/iva/total siguen
  // en 2 decimales (ya redondeado al asentar contabilidad).
  precioUnitario Decimal @db.Decimal(18, 4)
  subtotal       Decimal @db.Decimal(18, 2)
  iva            Decimal @db.Decimal(18, 2)
  total          Decimal @db.Decimal(18, 2)

  venta    Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])
}

// ============================================================
// PEDIDOS (Órdenes de Compra y de Venta)
// ============================================================

model PedidoCompra {
  id            Int          @id @default(autoincrement())
  numero        String       @unique
  proveedorId   String
  fecha         DateTime
  fechaPrevista DateTime?
  moneda        Moneda
  tipoCambio    Decimal      @default(1) @db.Decimal(18, 6)
  estado        PedidoEstado @default(BORRADOR)
  observaciones String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  proveedor Proveedor          @relation(fields: [proveedorId], references: [id])
  items     ItemPedidoCompra[]
  compras   Compra[]
  embarques Embarque[]

  @@index([proveedorId])
  @@index([estado])
}

model ItemPedidoCompra {
  id             Int     @id @default(autoincrement())
  pedidoCompraId Int
  productoId     String
  cantidad       Int
  precioUnitario Decimal @db.Decimal(18, 2)

  pedido   PedidoCompra @relation(fields: [pedidoCompraId], references: [id], onDelete: Cascade)
  producto Producto     @relation(fields: [productoId], references: [id])

  @@index([pedidoCompraId])
}

model PedidoVenta {
  id            Int          @id @default(autoincrement())
  numero        String       @unique
  clienteId     String
  fecha         DateTime
  fechaPrevista DateTime?
  moneda        Moneda
  tipoCambio    Decimal      @default(1) @db.Decimal(18, 6)
  estado        PedidoEstado @default(BORRADOR)
  observaciones String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  cliente Cliente           @relation(fields: [clienteId], references: [id])
  items   ItemPedidoVenta[]
  ventas  Venta[]

  @@index([clienteId])
  @@index([estado])
}

model ItemPedidoVenta {
  id             Int     @id @default(autoincrement())
  pedidoVentaId  Int
  productoId     String
  cantidad       Int
  precioUnitario Decimal @db.Decimal(18, 2)

  pedido   PedidoVenta @relation(fields: [pedidoVentaId], references: [id], onDelete: Cascade)
  producto Producto    @relation(fields: [productoId], references: [id])

  @@index([pedidoVentaId])
}

